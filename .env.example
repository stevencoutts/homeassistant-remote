# Copy to .env (gitignored) and fill in. The container proxies HA using these;
# the token never reaches a browser. Leave unset to serve static-only (each
# device then enters its own URL/token).
HA_URL=http://homeassistant.local:8123
HA_TOKEN=your-long-lived-access-token

# Optional: Emby Live TV guide. Set both to enable the TV guide; the API key is
# injected server-side and never reaches a browser. Create the key in Emby under
# Settings -> Advanced -> API Keys.
EMBY_URL=http://emby.local:8096
EMBY_API_KEY=your-emby-api-key
# Optional overrides (auto-detected if unset):
#   EMBY_USER_ID — the Emby user whose Live TV channels are shown
#   EMBY_APPLE_TV_DEVICE — Emby session DeviceName for the room's Apple TV
