# Copy to .env (gitignored) and fill in. The container proxies HA using these;
# the token never reaches a browser. Leave unset to serve static-only (each
# device then enters its own URL/token).
HA_URL=http://homeassistant.local:8123
HA_TOKEN=your-long-lived-access-token

# Optional: Emby. Set both to enable the TV Guide and the Films & TV on-demand
# browser on the media card; the API key is injected server-side and never
# reaches a browser. Create the key in Emby under Settings -> Advanced -> API
# Keys. The Emby user and the room's playback session are auto-detected.
EMBY_URL=http://emby.local:8096
EMBY_API_KEY=your-emby-api-key

# Optional: Plex track ratings (thumbs up/down on the media card). Set both to
# enable; the token is injected server-side and never reaches a browser. Find
# your token via Plex Web (X-Plex-Token), or account settings.
PLEX_URL=http://plex.local:32400
PLEX_TOKEN=your-plex-token
